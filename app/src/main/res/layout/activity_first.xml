<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue">

    <!-- 主要内容区域 -->
    <ScrollView
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation"
        android:padding="16dp"
        android:paddingBottom="12dp"        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/mainLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_rounded_white_blue"
            android:minHeight="600dp">

            <!-- 标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="随手记"
                android:textSize="24sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.01" />


            <!-- 输入框带阴影 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_rounded_white_blue"
                android:layout_marginBottom="20dp"
                android:elevation="2dp">

                <EditText
                    android:id="@+id/inputArea"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="记录此刻的想法..."
                    android:gravity="top"
                    android:padding="14dp"
                    android:background="@android:color/transparent"
                    android:textColor="@color/text_primary"
                    android:minHeight="120dp" />
            </LinearLayout>

            <!-- 图片预览区域 -->
            <LinearLayout
                android:id="@+id/imagePreviewLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="图片预览"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_rounded_white_blue"
                    android:padding="4dp" />

                <Button
                    android:id="@+id/removeImageButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="移除图片"
                    android:textColor="@color/delete_blue"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <!-- 录音预览布局 -->
            <LinearLayout
                android:id="@+id/voicePreviewLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_white_blue"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="语音预览"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- 语音图标 -->
                    <TextView
                        android:id="@+id/voicePreviewIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🔊"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:background="@drawable/bg_rounded_white_blue"
                        android:layout_marginEnd="12dp" />

                    <!-- 语音信息 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/voicePreviewDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/voicePreviewStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已录制"
                            android:textSize="12sp"
                            android:textColor="@color/text_gray"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- 删除按钮 -->
                    <Button
                        android:id="@+id/removeVoiceButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="删除"
                        android:textColor="@color/delete_blue"
                        android:background="?android:attr/selectableItemBackground"
                        android:padding="8dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 快速操作 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <!-- 左边留空 -->
                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="0.5" />

                <!-- 照片按钮 -->
                <LinearLayout
                    android:id="@+id/photoLayout"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_circle_gradient_blue"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginRight="24dp">


                    <ImageView
                        android:id="@+id/ivPhoto"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_photo_blue"
                        android:contentDescription="照片"
                        android:layout_gravity="center"
                        app:tint="@color/icon_blue_selector" />

                </LinearLayout>

                <!-- 语音按钮 -->
                <LinearLayout
                    android:id="@+id/voiceLayout"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_circle_gradient_blue"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginRight="24dp">

                    <ImageView
                        android:id="@+id/ivVoice"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_voice_blue"
                        android:contentDescription="语音"
                        android:layout_gravity="center"
                        app:tint="@color/icon_blue_selector" />

                </LinearLayout>

                <!-- 心情按钮 -->
                <LinearLayout
                    android:id="@+id/moodLayout"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_circle_gradient_blue"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginRight="24dp">

                    <ImageView
                        android:id="@+id/ivMoodIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_mood_blue"
                        android:contentDescription="心情"
                        android:layout_gravity="center"
                        app:tint="@color/icon_blue_selector" />

                    <TextView
                        android:id="@+id/tvMoodText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/card_white"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_gravity="center"
                        android:visibility="gone" />


                </LinearLayout>

                <!-- 标签按钮 -->
                <LinearLayout
                    android:id="@+id/tagLayout"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_circle_gradient_blue"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivTagIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_tag_blue"
                        android:contentDescription="标签"
                        android:layout_gravity="center"
                        app:tint="@color/icon_blue_selector" />

                    <TextView
                        android:id="@+id/tvTagText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="16sp"
                        android:textColor="@color/card_white"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:layout_gravity="center"
                        android:visibility="gone" />


                </LinearLayout>

                <!-- 右边留空 -->
                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="0.5" />

            </LinearLayout>

            <!-- 确定按钮 -->
            <Button
                android:id="@+id/confirmButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="确定"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_primary_blue"
                android:textColor="@android:color/white"
                android:layout_marginBottom="24dp"
                android:visibility="gone" />

            <!-- 今日记录标题 -->
            <TextView
                android:id="@+id/todayRecordsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="今日记录"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- 空白状态提示 -->
            <TextView
                android:id="@+id/emptyStateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="还没有任何记录，开始记录您的一天吧！"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="visible" />

            <!-- 时间线记录容器 -->
            <LinearLayout
                android:id="@+id/timelineContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 这里将动态添加带删除按钮的笔记 -->
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 底部导航栏 - 固定在屏幕底部 -->
    <include
        android:id="@+id/bottom_navigation"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>