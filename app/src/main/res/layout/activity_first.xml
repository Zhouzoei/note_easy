<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5">

    <!-- 主要内容区域 -->
    <ScrollView
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:paddingBottom="80dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/mainLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_rounded_white"
            android:minHeight="600dp">

            <!-- 标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="随手记"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="8dp" />


            <!-- 输入区域 -->
            <EditText
                android:id="@+id/inputArea"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="记录此刻的想法..."
                android:gravity="top"
                android:padding="12dp"
                android:background="@drawable/bg_rounded_border"
                android:layout_marginBottom="16dp" />

            <!-- 图片预览区域 -->
            <LinearLayout
                android:id="@+id/imagePreviewLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="图片预览"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_dashed_border"
                    android:padding="4dp" />

                <Button
                    android:id="@+id/removeImageButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="移除图片"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:background="@android:color/transparent"
                    android:textColor="#FF5252" />
            </LinearLayout>

            <!-- 快速操作 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <!-- 照片按钮 -->
                <LinearLayout
                    android:id="@+id/photoLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="照片"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- 语音按钮 -->
                <LinearLayout
                    android:id="@+id/voiceLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎤"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="语音"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- 心情按钮 -->
                <LinearLayout
                    android:id="@+id/moodLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😊"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/moodText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="心情"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- 标签按钮 -->
                <LinearLayout
                    android:id="@+id/tagLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏷️"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tagText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="标签"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 确定按钮 -->
            <Button
                android:id="@+id/confirmButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="确定"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_rounded_primary"
                android:textColor="@android:color/white"
                android:layout_marginBottom="24dp"
                android:visibility="gone" />

            <!-- 今日记录标题 -->
            <TextView
                android:id="@+id/todayRecordsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="今日记录"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- 空白状态提示 -->
            <TextView
                android:id="@+id/emptyStateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="还没有任何记录，开始记录您的一天吧！"
                android:textSize="14sp"
                android:textColor="#666666"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="visible" />

            <!-- 时间线记录容器 -->
            <LinearLayout
                android:id="@+id/timelineContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 这里将动态添加带删除按钮的笔记 -->
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 底部导航栏 - 固定在屏幕底部 -->
    <include
        android:id="@+id/bottom_navigation"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>