<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_navigation"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#f0f0f0"
    android:padding="6dp">

    <LinearLayout
        android:id="@+id/nav_record"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="2dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/icon_record"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_new_record"
            android:adjustViewBounds="true"
            app:tint="#999999" />

        <TextView
            android:id="@+id/text_record"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="记录"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_organize"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="2dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/icon_organize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_new_folder"
            android:adjustViewBounds="true"
            app:tint="#999999" />

        <TextView
            android:id="@+id/text_organize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="整理"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_stats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="2dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/icon_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_new_chart"
            android:adjustViewBounds="true"
            app:tint="#999999" />

        <TextView
            android:id="@+id/text_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_profile"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="2dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/icon_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_new_person"
            android:adjustViewBounds="true"
            app:tint="#999999" />

        <TextView
            android:id="@+id/text_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="个人"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>
</LinearLayout>
