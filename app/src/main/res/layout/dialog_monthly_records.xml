<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="记录查看"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 日期选择 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnPrevDay"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="◀"
                android:textSize="16sp"
                android:background="@drawable/bg_outline_button"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvCurrentDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2024年1月15日"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                android:layout_marginHorizontal="12dp" />

            <Button
                android:id="@+id/btnNextDay"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="▶"
                android:textSize="16sp"
                android:background="@drawable/bg_outline_button"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- 日期统计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当日记录"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvDayRecordsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#e0e0e0" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="含语音"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvDayVoiceCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800" />
            </LinearLayout>
        </LinearLayout>

        <!-- 日记列表标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="日记列表"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <!-- 日记列表容器 - 这里也需要滚动 -->
        <ScrollView
            android:id="@+id/scrollViewRecords"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="#f8f9fa"
            android:padding="8dp"
            android:scrollbars="vertical">

            <LinearLayout
                android:id="@+id/recordsListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 这里通过Java代码动态添加日记项 -->
                <!-- 默认显示无数据提示 -->
                <TextView
                    android:id="@+id/tvNoRecords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="当日暂无日记记录"
                    android:textSize="14sp"
                    android:textColor="#999999"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="visible" />

            </LinearLayout>
        </ScrollView>

        <!-- 底部按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnViewMonth"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="查看本月"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_outline_button"
                android:textColor="#2196F3" />

            <Button
                android:id="@+id/btnClose"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="关闭"
                android:textSize="16sp"
                android:background="@drawable/bg_rounded_button_primary"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>