<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@color/background_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="记录查看"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- 日期选择 -->
        <!-- 日期选择 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:background="@android:color/transparent">

            <ImageView
                android:id="@+id/btnPrevDay"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:textSize="25sp"
                android:src="@drawable/ic_circle_left"
                android:gravity="center"
                android:padding="0dp"
                android:stateListAnimator="@null"
                app:tint="#A0CFF4" />

            <TextView
                android:id="@+id/tvCurrentDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2024年1月15日"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp" />

            <ImageView
                android:id="@+id/btnNextDay"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_circle_right"
                android:gravity="center"
                android:padding="0dp"
                android:stateListAnimator="@null"
                app:tint="#A0CFF4"/>

        </LinearLayout>

        <!-- 日期统计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_rounded_white_blue"
            android:elevation="2dp"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当日记录"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvDayRecordsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/primary_blue" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="#BBDEFB" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="含语音"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvDayVoiceCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/primary_blue" />
            </LinearLayout>
        </LinearLayout>

        <!-- 日记列表容器 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_rounded_white_blue"
            android:elevation="2dp"
            android:padding="16dp">

            <!-- 日记列表标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="日记列表"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <!-- 日记列表容器 -->
            <ScrollView
                android:id="@+id/scrollViewRecords"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@android:color/transparent"
                android:padding="4dp"
                android:scrollbars="vertical"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/recordsListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 这里通过Java代码动态添加日记项 -->
                    <!-- 默认显示无数据提示 -->
                    <TextView
                        android:id="@+id/tvNoRecords"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="当日暂无日记记录"
                        android:textSize="14sp"
                        android:textColor="@color/text_gray"
                        android:gravity="center"
                        android:padding="40dp"
                        android:visibility="visible" />

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <!-- 底部按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:divider="@drawable/divider_vertical"
            android:showDividers="middle"
            android:dividerPadding="4dp">

            <Button
                android:id="@+id/btnViewMonth"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="查看本月"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_dashed_border_dark_blue"
                android:textColor="@color/text_primary"
                android:stateListAnimator="@null"
                android:elevation="2dp" />

            <View
                android:layout_width="16dp"
                android:layout_height="1dp" />


            <Button
                android:id="@+id/btnClose"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="关闭"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_btn_primary_blue"
                android:textColor="#FFFFFF"
                android:stateListAnimator="@null"
                android:elevation="4dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>