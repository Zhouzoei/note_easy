<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue">

    <!-- 主要内容区域 -->
    <ScrollView
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="80dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="笔记统计"
                android:textSize="24sp"
                android:fontFamily="sans-serif-light"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:letterSpacing="0.01"
                android:layout_marginBottom="20dp" />

            <!-- 月份选择器 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/btnPreviousMonth"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:textSize="25sp"
                    android:src="@drawable/ic_circle_left"
                    android:gravity="center"
                    android:padding="0dp"
                    android:stateListAnimator="@null"
                    app:tint="#A0CFF4" />

                <TextView
                    android:id="@+id/tvHeatmapTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2023年11月"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:layout_marginLeft="12dp"
                    android:layout_marginRight="12dp" />

                <ImageView
                    android:id="@+id/btnNextMonth"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_circle_right"
                    android:gravity="center"
                    android:padding="0dp"
                    android:stateListAnimator="@null"
                    app:tint="#A0CFF4"/>

            </LinearLayout>

            <!-- 田字格统计卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <!-- 第一行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- 月度记录 -->
                    <LinearLayout
                        android:id="@+id/monthlyRecordsLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_dashed_border_blue"
                        android:padding="16dp"
                        android:layout_marginRight="10dp"
                        android:gravity="center"
                        android:minHeight="120dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="月度记录"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary"
                            android:alpha="0.9"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvMonthlyRecords"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="42"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- 照片总数 -->
                    <LinearLayout
                        android:id="@+id/totalPhotosLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_dashed_border_blue"
                        android:padding="16dp"
                        android:layout_marginLeft="10dp"
                        android:gravity="center"
                        android:minHeight="120dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="照片总数"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary"
                            android:alpha="0.9"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvTotalPhotos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="128"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 第二行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 主要心情 -->
                    <LinearLayout
                        android:id="@+id/primaryMoodLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_dashed_border_blue"
                        android:padding="16dp"
                        android:layout_marginRight="10dp"
                        android:gravity="center"
                        android:minHeight="120dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="主要心情"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary"
                            android:alpha="0.9"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvPrimaryMood"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="平静"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                    <!-- 常用标签 -->
                    <LinearLayout
                        android:id="@+id/commonTagsLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_dashed_border_blue"
                        android:padding="16dp"
                        android:layout_marginLeft="10dp"
                        android:gravity="center"
                        android:minHeight="120dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="常用标签"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary"
                            android:alpha="0.9"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvCommonTags"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7"
                            android:textSize="24sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- 心情日历 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_white_blue"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="心情日历"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- 星期标题 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="日"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="一"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="二"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="三"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="四"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="五"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="六"
                        android:textSize="12sp"
                        android:textColor="@color/text_gray"
                        android:gravity="center" />

                </LinearLayout>

                <!-- 心情日历网格 -->
                <LinearLayout
                    android:id="@+id/moodHeatmapContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@android:color/transparent">

                    <!-- 这里动态添加心情日历行 -->

                </LinearLayout>

            </LinearLayout>

            <!-- 活动趋势图表 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_white_blue"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="活动趋势"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/activityChartContainer"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:padding="4dp"
                    android:background="@android:color/transparent">

                    <!-- 这里动态添加柱状图 -->

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chartLabelsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:background="@android:color/transparent">

                    <!-- 这里动态添加月份标签 -->

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 底部导航栏 - 固定在屏幕底部 -->
    <include
        android:id="@+id/bottom_navigation"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>