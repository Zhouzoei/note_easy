<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f9f9f9">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:layout_above="@+id/bottom_navigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="整理碎片"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <!-- 选择日期 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="15dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="选择日期"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="5dp" />

                <EditText
                    android:id="@+id/diary_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="选择日期"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:background="@drawable/bg_rounded_border" />

            </LinearLayout>

            <!-- 日记标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="日记标题"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="5dp" />

                <EditText
                    android:id="@+id/diary_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="请输入日记标题"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:background="@drawable/bg_rounded_border" />

            </LinearLayout>

            <!-- 可添加的碎片 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="可添加的碎片"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/available_fragments_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="25dp">

                <!-- 碎片1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded_border"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="5dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="2025-10-15 14:30"
                            android:textSize="14sp"
                            android:textColor="#666666" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="工作"
                                android:textSize="12sp"

                                android:padding="4dp"
                                android:layout_marginEnd="5dp"
                                android:textColor="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="灵感"
                                android:textSize="12sp"

                                android:padding="4dp"
                                android:textColor="#FFFFFF" />

                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="今天开会时突然想到一个产品改进的点子，应该可以提升用户体验..."
                        android:textSize="16sp"
                        android:layout_marginBottom="10dp" />

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="添加到日记"
                        android:textSize="14sp"
                        android:padding="8dp"

                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- 已选择的碎片 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="已选择的碎片"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/selected_fragments_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="25dp">

                <!-- 已选择碎片 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_rounded_border"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="5dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="2025-10-13 09:45"
                            android:textSize="14sp"
                            android:textColor="#666666" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="学习"
                                android:textSize="12sp"

                                android:padding="4dp"
                                android:textColor="#FFFFFF" />

                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="阅读了一篇关于时间管理的文章，学到了番茄工作法的进阶技巧..."
                        android:textSize="16sp"
                        android:layout_marginBottom="10dp" />

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="移除"
                        android:textSize="14sp"
                        android:padding="8dp"

                        android:textColor="#333333"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- 生成日记按钮 -->
            <Button
                android:id="@+id/generate_diary_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="生成日记"
                android:textSize="16sp"
                android:padding="15dp"

                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <!-- 日记预览 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_border"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2025年10月15日"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:textColor="#666666"
                    android:layout_marginBottom="15dp" />

                <TextView
                    android:id="@+id/diary_preview_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="今天阅读了一篇关于时间管理的文章，学到了番茄工作法的进阶技巧..."
                    android:textSize="16sp"
                    android:lineSpacingMultiplier="1.2" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 底部导航栏 - 固定在屏幕底部 -->
    <include
        android:id="@+id/bottom_navigation"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>