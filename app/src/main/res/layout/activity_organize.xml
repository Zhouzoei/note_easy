<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue">

    <!-- 标题区域 -->
    <TextView
        android:id="@+id/title_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="碎片整理"
        android:textSize="24sp"
        android:fontFamily="sans-serif-light"
        android:textColor="@color/text_primary"
        android:letterSpacing="0.01"
        android:padding="10dp"
        android:layout_marginBottom="10dp"
        android:layout_alignParentTop="true"
        android:gravity="center" />

    <!-- Tab切换区域 -->
    <LinearLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/title_text"
        android:orientation="horizontal"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_tab_rounded_blue"
        android:padding="4dp">

        <Button
            android:id="@+id/tab_fragments"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="今日碎片"
            android:textSize="14sp"
            android:textColor="@color/primary_blue"
            android:background="@drawable/bg_tab_white_rounded"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:stateListAnimator="@null"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/tab_diary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="今日日记"
            android:textSize="14sp"
            android:textColor="@color/text_gray"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:stateListAnimator="@null"
            style="@style/Widget.AppCompat.Button.Borderless" />
    </LinearLayout>

    <!-- 1. AI整合按钮 -->
    <Button
        android:id="@+id/ai_process_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🤖 AI整合碎片"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_btn_primary_blue"
        android:textColor="#FFFFFF"
        android:layout_below="@id/tab_layout"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="12dp"
        android:stateListAnimator="@null"
        android:elevation="4dp" />

    <!-- 2. 风格选择头部 -->
    <LinearLayout
        android:id="@+id/style_header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@id/ai_process_btn"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_rounded_white_blue"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="写作风格：简洁"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:drawablePadding="8dp"
            android:id="@+id/tv_current_style" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/arrow_down_float"
            android:id="@+id/iv_style_expand_arrow"
            android:rotation="0" />
    </LinearLayout>

    <!-- 3. 风格选项详情 -->
    <LinearLayout
        android:id="@+id/style_options_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/style_header_layout"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_rounded_white_blue"
        android:padding="12dp"
        android:visibility="gone">

        <RadioGroup
            android:id="@+id/style_radio_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/style_simple"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="简洁风格 - 简练明了，突出重点"
                android:textSize="13sp"
                android:checked="true"
                android:button="@null"
                android:background="@drawable/bg_style_selection_blue"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:textColor="@drawable/bg_style_selected_blue" />

            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/style_literary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="文艺风格 - 优美文字，情感丰富"
                android:textSize="13sp"
                android:button="@null"
                android:background="@drawable/bg_style_selection_blue"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:textColor="@drawable/bg_style_selected_blue" />

            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/style_humorous"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="轻松幽默风格 - 有趣活泼，语调轻松"
                android:textSize="13sp"
                android:button="@null"
                android:background="@drawable/bg_style_selection_blue"
                android:padding="12dp"
                android:layout_marginBottom="0dp"
                android:gravity="center_vertical"
                android:textColor="@drawable/bg_style_selected_blue" />
        </RadioGroup>
    </LinearLayout>

    <!-- 今日碎片内容区域 -->
    <ScrollView
        android:id="@+id/fragments_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/style_options_layout"
        android:layout_above="@+id/bottom_navigation"
        android:padding="20dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/emptyStateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="今天还没有任何碎片，快去记录一下吧！"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="visible" />

            <LinearLayout
                android:id="@+id/fragment_control_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/select_all_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="全选"
                    android:textSize="14sp"
                    android:textColor="@color/primary_blue"
                    android:checked="true" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="选择要整理的碎片"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginLeft="8dp" />

                <TextView
                    android:id="@+id/selected_count_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已选择 0 项"
                    android:textSize="12sp"
                    android:textColor="@color/card_white"
                    android:background="@drawable/bg_primary_mood_blue"
                    android:padding="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/timelineContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <!-- 今日日记内容区域 -->
    <ScrollView
        android:id="@+id/diary_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/style_options_layout"
        android:layout_above="@+id/bottom_navigation"
        android:padding="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 日记标题和状态 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_rounded_white_blue"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/diary_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2024年12月16日"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/diary_status"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:text="未生成"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/bg_circle_gradient_blue"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>

            <!-- AI结果区域 -->
            <LinearLayout
                android:id="@+id/ai_result_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_white_blue"
                android:elevation="2dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✨ AI整合结果"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary"
                    android:padding="12dp"
                    android:background="#F8F9FA"
                    android:gravity="center" />

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="300dp"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/result_content_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/ai_result_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="等待AI处理..."
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </ScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btn_edit_result"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="编辑"
                        android:textSize="14sp"
                        android:layout_marginRight="4dp"
                        android:background="@drawable/bg_rec_gradient_blue"
                        android:textColor="@color/text_primary"
                        android:stateListAnimator="@null"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btn_save_result"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保存为日记"
                        android:textSize="14sp"
                        android:layout_marginRight="4dp"
                        android:background="@drawable/bg_btn_primary_blue"
                        android:textColor="#FFFFFF"
                        android:stateListAnimator="@null"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btn_clear_result"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="清空结果"
                        android:textSize="14sp"
                        android:layout_marginLeft="4dp"
                        android:background="@drawable/bg_dashed_border_dark_blue"
                        android:textColor="@color/text_primary"
                        android:stateListAnimator="@null"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- 日记编辑区域 -->
            <LinearLayout
                android:id="@+id/diary_edit_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_white_blue"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="编辑日记"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btn_cancel_edit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="取消"
                        android:textSize="12sp"
                        android:background="@drawable/bg_outline_button_blue"
                        android:textColor="@color/text_primary"
                        android:layout_marginRight="8dp"
                        android:stateListAnimator="@null" />

                    <Button
                        android:id="@+id/btn_save_edit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="保存"
                        android:textSize="12sp"
                        android:background="@drawable/bg_btn_primary_blue"
                        android:textColor="#FFFFFF"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <EditText
                    android:id="@+id/diary_content_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp"
                    android:gravity="top"
                    android:hint="在此编辑日记内容..."
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="#999999"
                    android:background="@drawable/bg_rounded_white_blue"
                    android:elevation="2dp"
                    android:padding="12dp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <!-- 原始内容展示区域 -->
            <LinearLayout
                android:id="@+id/original_content_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_rounded_white_blue"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📷 今日图片"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/diary_images_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎤 今日语音"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/diary_voices_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 底部导航栏 -->
    <include
        android:id="@+id/bottom_navigation"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>
