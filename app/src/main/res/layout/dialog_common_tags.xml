<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="本月常用标签"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- 标签统计 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="常用标签数"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvCommonTagsCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#9C27B0" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:background="#e0e0e0" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最常用"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvMostUsedTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="无"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#9C27B0"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- 标签云标题和刷新按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="标签云"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <Button
            android:id="@+id/btnRefreshCloud"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="刷新"
            android:textSize="12sp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_outline_button"
            android:textColor="#9C27B0" />
    </LinearLayout>

    <!-- 标签云容器 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:background="#f8f9fa"
        android:padding="4dp">

        <!-- 自定义词云View -->
        <com.example.finalwork.WordCloudView
            android:id="@+id/wordCloudView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 无标签提示 -->
        <TextView
            android:id="@+id/tvNoTags"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="本月暂无标签"
            android:textSize="16sp"
            android:textColor="#999999"
            android:gravity="center"
            android:visibility="gone" />

    </FrameLayout>

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="关闭"
            android:textSize="16sp"
            android:background="@drawable/bg_rounded_primary"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>