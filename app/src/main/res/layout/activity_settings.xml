<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_blue">

    <!-- 主要内容区域（可滚动） -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_rounded_white_blue"
            android:padding="24dp"
            android:elevation="4dp">

            <!-- 标题 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设置"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue"
                    android:fontFamily="sans-serif-medium"
                    android:padding="12dp" />

            </LinearLayout>

            <!-- 修改用户名 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="修改用户名"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:paddingBottom="8dp"
                    android:fontFamily="sans-serif-medium" />

                <EditText
                    android:id="@+id/etNewUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dashed_border_blue"
                    android:padding="16dp"
                    android:hint="输入新用户名"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_gray" />

            </LinearLayout>

            <!-- 修改密码 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="修改密码"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:paddingBottom="8dp"
                    android:fontFamily="sans-serif-medium" />

                <EditText
                    android:id="@+id/etOldPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dashed_border_blue"
                    android:padding="16dp"
                    android:hint="输入旧密码"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_gray"
                    android:inputType="textPassword"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dashed_border_blue"
                    android:padding="16dp"
                    android:hint="输入新密码"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_gray"
                    android:inputType="textPassword" />

            </LinearLayout>

            <!-- 设置生日 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="30dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="设置生日"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:paddingBottom="8dp"
                    android:fontFamily="sans-serif-medium" />

                <!-- 生日显示和选择按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvBirthdayDisplay"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_dashed_border_blue"
                        android:padding="16dp"
                        android:text="未选择"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginEnd="12dp"/>

                    <Button
                        android:id="@+id/btnSelectBirthday"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选择"
                        android:textSize="14sp"
                        android:background="@drawable/bg_rec_gradient_blue"
                        android:textColor="@color/text_primary"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp"
                        android:elevation="2dp"
                        android:stateListAnimator="@null"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

            </LinearLayout>

            <!-- 保存按钮 -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="保存设置"
                android:textStyle="bold"
                android:textSize="16sp"
                android:background="@drawable/bg_btn_primary_blue"
                android:textColor="@android:color/white"
                android:layout_marginBottom="16dp"
                android:padding="16dp"
                android:elevation="4dp"
                android:stateListAnimator="@null"
                android:fontFamily="sans-serif-medium" />

            <!-- 返回按钮 -->
            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="返回"
                android:textSize="16sp"
                android:background="@drawable/bg_dashed_border_dark_blue"
                android:textColor="@color/text_primary"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:fontFamily="sans-serif-medium" />

            <!-- 错误信息提示 -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/error_red"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:padding="12dp"
                android:background="@drawable/bg_error_rounded_blue" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>