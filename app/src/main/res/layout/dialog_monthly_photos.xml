<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/totalPhotosLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/background_blue">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="本月照片"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- 统计信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_rounded_white_blue"
        android:elevation="2dp"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="本月照片"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTotalPhotosCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/primary_blue" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="#BBDEFB" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="有图日记"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvNotesWithPhotos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="24sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/primary_blue" />
        </LinearLayout>
    </LinearLayout>

    <!-- 照片预览区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded_white_blue"
        android:elevation="2dp"
        android:padding="16dp">

        <!-- 照片预览标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="照片预览"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <!-- ====== 新增：添加滚动视图 ====== -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <!-- 网格布局容器 -->
            <!-- 注意：height 改为了 wrap_content，不再限制为 280dp -->
            <LinearLayout
                android:id="@+id/photosGridContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/transparent"
                android:padding="8dp">

                <!-- 这里通过Java代码动态添加照片 -->
                <!-- 默认显示无照片提示 -->
                <TextView
                    android:id="@+id/tvNoPhotos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本月暂无照片"
                    android:textSize="14sp"
                    android:textColor="@color/text_gray"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:visibility="visible" />

            </LinearLayout>

        </ScrollView>
        <!-- ====== 滚动视图结束 ====== -->

    </LinearLayout>

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="关闭"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_btn_primary_blue"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:elevation="4dp" />

    </LinearLayout>

</LinearLayout>
