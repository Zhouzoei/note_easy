<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded_white_blue"
    android:padding="24dp"
    android:layout_margin="20dp"
    android:elevation="8dp"
    android:minHeight="320dp">

    <!-- 标题和关闭按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="语音记录"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close_blue"
            android:background="@null"
            android:scaleType="center"
            android:contentDescription="关闭"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp" />

    </LinearLayout>

    <!-- 录音状态 -->
    <TextView
        android:id="@+id/tvRecordingStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="点击下方按钮开始录音"
        android:textSize="16sp"
        android:textColor="@color/text_gray"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- 录音时间 -->
    <TextView
        android:id="@+id/tvRecordingTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- 录音按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp">

            <!-- 圆形背景 -->
            <View
                android:id="@+id/circleBackground"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_circle_gradient_blue"
                android:alpha="0.3" />

            <!-- 录音按钮 -->
            <TextView
                android:id="@+id/btnRecord"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:text="🎤"
                android:textSize="36sp"
                android:gravity="center"
                android:background="@drawable/bg_record_circle_blue"
                android:textColor="@android:color/white"
                android:clickable="true"
                android:focusable="true"
                android:elevation="4dp" />

            <!-- 录音动画波纹 -->
            <View
                android:id="@+id/rippleEffect"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_ripple_blue"
                android:visibility="invisible" />
        </FrameLayout>

        <!-- 录音提示 -->
        <TextView
            android:id="@+id/tvRecordHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="点击录音，再次点击结束"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- 录音预览区域 -->
    <LinearLayout
        android:id="@+id/playbackSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_rounded_white_blue"
        android:padding="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="录音预览"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/transparent"
            android:padding="8dp">

            <!-- 播放按钮 -->
            <TextView
                android:id="@+id/btnPlay"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="▶️"
                android:textSize="24sp"
                android:gravity="center"
                android:background="@drawable/bg_circle_gradient_blue"
                android:textColor="@android:color/white"
                android:clickable="true"
                android:focusable="true"
                android:elevation="2dp" />

            <!-- 播放进度 -->
            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:progress="0"
                android:max="100"
                android:progressTint="@color/primary_blue"
                android:thumbTint="@color/primary_blue" />

            <!-- 播放时间 -->
            <TextView
                android:id="@+id/tvPlayTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="12sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center">

            <Button
                android:id="@+id/btnDiscard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="重录"
                android:textColor="@color/background_blue"
                android:textSize="16sp"
                android:background="@drawable/bg_btn_primary_blue"
                android:layout_marginEnd="8dp"
                android:elevation="1dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnUseAudio"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="使用录音"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:background="@drawable/bg_dashed_border_dark_blue"
                android:layout_marginStart="8dp"
                android:elevation="2dp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>